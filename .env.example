# ─────────────────────────────────────────────────────────────
#  Variables d'environnement — Espace admin (/admin)
#  NE JAMAIS committer .env.local (il est gitignoré).
#  En production : Vercel → Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────
#
#  Génère ces valeurs automatiquement avec :
#     npm run set-admin
#  (il te demande un mot de passe, calcule le hash et écrit .env.local ;
#   le mot de passe en clair n'est jamais stocké nulle part.)
#
# ─────────────────────────────────────────────────────────────

# Identifiant de connexion
ADMIN_USERNAME=lalzin

# Hash PBKDF2 du mot de passe (JAMAIS le mot de passe en clair).
# Format : iterations.salt.hash  — généré par `npm run set-admin`.
ADMIN_PASSWORD_HASH=

# Secret de signature des sessions (HMAC). 32 octets aléatoires.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
