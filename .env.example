# ─────────────────────────────────────────────────────────────
#  Variables d'environnement LALZIN
#  NE JAMAIS committer .env.local (gitignoré).
#  En production : Vercel → Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# ── Admin (/admin) ───────────────────────────────────────────
# Génère ADMIN_PASSWORD_HASH + AUTH_SECRET avec :  npm run set-admin
ADMIN_USERNAME=lalzin
ADMIN_PASSWORD_HASH=
AUTH_SECRET=

# ── Supabase (persistance du contenu / CMS live) ─────────────
# Depuis ton projet Supabase → Settings → API :
#   SUPABASE_URL             = "Project URL"
#   SUPABASE_SERVICE_ROLE_KEY = clé "service_role" (SECRÈTE, côté serveur only)
# ⚠️ Ne PAS préfixer par NEXT_PUBLIC — ces clés ne doivent jamais partir au client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
